# I-type instructions test file
# Format: one 32-bit hex instruction per line

# --- Arithmetic ---
# ADDI x2, x0, 5       -> imm=5, rs1=x0, funct3=0x0, rd=x2, opcode=0x13
00500113
# ADDI x3, x0, -1      -> imm=-1 (0xFFF), rs1=x0, funct3=0x0, rd=x3, opcode=0x13
FFF00193
# ANDI x4, x3, 15      -> imm=15, rs1=x3, funct3=0x7, rd=x4, opcode=0x13
00F1F213
# ORI  x5, x3, 8       -> imm=8, rs1=x3, funct3=0x6, rd=x5, opcode=0x13
0081E293
# XORI x6, x3, 255     -> imm=255, rs1=x3, funct3=0x4, rd=x6, opcode=0x13
0FF1C313
# SLTI x7, x2, 10      -> imm=10, rs1=x2, funct3=0x2, rd=x7, opcode=0x13
00A12393
# SLTIU x8, x2, 10     -> imm=10, rs1=x2, funct3=0x3, rd=x8, opcode=0x13
00A13413
# SLLI x9, x2, 3       -> imm=3, rs1=x2, funct3=0x1, rd=x9, opcode=0x13
00311493
# SRLI x10, x2, 3      -> imm=3, rs1=x2, funct3=0x5, rd=x10, opcode=0x13
00315513
# SRAI x11, x2, 3      -> imm=0x403, rs1=x2, funct3=0x5, rd=x11, opcode=0x13
40315593

# --- Loads ---
# LB  x12, 0(x1)       -> imm=0, rs1=x1, funct3=0x0, rd=x12, opcode=0x03
00008603
# LH  x13, 2(x1)       -> imm=2, rs1=x1, funct3=0x1, rd=x13, opcode=0x03
00209683
# LW  x14, 4(x1)       -> imm=4, rs1=x1, funct3=0x2, rd=x14, opcode=0x03
0040A703
# LBU x15, 0(x1)       -> imm=0, rs1=x1, funct3=0x4, rd=x15, opcode=0x03
0000C783
# LHU x16, 2(x1)       -> imm=2, rs1=x1, funct3=0x5, rd=x16, opcode=0x03
0020D803

# --- JALR ---
